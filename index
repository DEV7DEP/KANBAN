<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kanban - Calculateur</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Segoe UI', system-ui, sans-serif; }
        .result { background: linear-gradient(135deg, #1e2937, #334155); }
    </style>
</head>
<body class="bg-zinc-950 text-white min-h-screen">
    <div class="max-w-4xl mx-auto p-8">
        <div class="text-center mb-10">
            <h1 class="text-4xl font-bold mb-2 text-emerald-400">🧮 Calculateur Kanban</h1>
            <p class="text-zinc-400">Calcul des paramètres d'approvisionnement</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- === INPUTS === -->
            <div class="bg-zinc-900 p-8 rounded-2xl border border-zinc-700">
                <h2 class="text-xl font-semibold mb-6 text-emerald-300">📥 Données d'entrée</h2>
                
                <div class="space-y-6">
                    <!-- UDI -->
                    <div>
                        <label class="block text-sm font-medium text-zinc-400 mb-2">UDI (Utilisation Journalière)</label>
                        <input id="udi" type="number" step="0.01" 
                               class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-5 py-4 text-lg focus:outline-none focus:border-emerald-500"
                               placeholder="ex: 150">
                    </div>

                    <!-- Délai de réapprovisionnement -->
                    <div>
                        <label class="block text-sm font-medium text-zinc-400 mb-2">Délai de réapprovisionnement (jours)</label>
                        <input id="delai" type="number" step="0.1" 
                               class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-5 py-4 text-lg focus:outline-none focus:border-emerald-500"
                               placeholder="ex: 5">
                    </div>

                    <!-- KE / jour et KE / mois -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-zinc-400 mb-2">KE / jour</label>
                            <input id="ke_jour" type="number" step="0.01" 
                                   class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-5 py-4 text-lg focus:outline-none focus:border-emerald-500"
                                   placeholder="ex: 1200">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-zinc-400 mb-2">KE / mois</label>
                            <input id="ke_mois" type="number" step="0.01" 
                                   class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-5 py-4 text-lg focus:outline-none focus:border-emerald-500"
                                   placeholder="ex: 36000">
                        </div>
                    </div>
                </div>

                <button onclick="calculer()" 
                        class="mt-8 w-full bg-emerald-600 hover:bg-emerald-500 transition-colors py-5 rounded-2xl font-semibold text-lg">
                    🔄 CALCULER
                </button>
            </div>

            <!-- === RÉSULTATS === -->
            <div class="result p-8 rounded-2xl border border-emerald-900/50">
                <h2 class="text-xl font-semibold mb-6 text-emerald-300">📤 Résultats</h2>
                
                <div class="space-y-6 text-lg">
                    <div class="flex justify-between items-center">
                        <span class="text-zinc-400">E (Quantité Économique) :</span>
                        <span id="result_E" class="font-mono text-2xl font-bold text-emerald-400">—</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-zinc-400">e (Stock de sécurité / min) :</span>
                        <span id="result_e" class="font-mono text-2xl font-bold text-amber-400">—</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-zinc-400">Intervalle entre deux livraisons (jours) :</span>
                        <span id="result_interval" class="font-mono text-2xl font-bold text-sky-400">—</span>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-zinc-700">
                    <p class="text-sm text-zinc-400 mb-2">💬 Commentaire</p>
                    <div id="commentaire" class="bg-zinc-800/50 p-5 rounded-2xl text-sm leading-relaxed text-zinc-300 min-h-[100px]">
                    </div>
                </div>
            </div>
        </div>

        <!-- === SIMULATION NUMÉRIQUE === -->
        <div class="mt-12 bg-zinc-900 p-8 rounded-2xl border border-zinc-700">
            <h2 class="text-xl font-semibold mb-6 text-emerald-300">📊 Simulation Numérique</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-sm">
                <div>
                    <label class="block mb-2 text-zinc-400">Nombre de périodes à simuler</label>
                    <input id="nb_periodes" type="number" value="30" 
                           class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3">
                </div>
                <div>
                    <button onclick="simuler()" 
                            class="w-full bg-sky-600 hover:bg-sky-500 transition-colors py-4 rounded-2xl font-semibold">
                        Lancer la simulation
                    </button>
                </div>
            </div>

            <div id="simulation_result" class="mt-8 font-mono text-xs bg-black/50 p-6 rounded-2xl overflow-auto max-h-96 text-emerald-300"></div>
        </div>

        <div class="text-center text-zinc-500 text-xs mt-12">
            Calculateur Kanban • Déployable sur GitHub Pages
        </div>
    </div>

    <script>
        function calculer() {
            const udi = parseFloat(document.getElementById('udi').value) || 0;
            const delai = parseFloat(document.getElementById('delai').value) || 0;
            let ke_jour = parseFloat(document.getElementById('ke_jour').value) || 0;
            const ke_mois = parseFloat(document.getElementById('ke_mois').value) || 0;

            // Si KE/mois rempli, convertir en KE/jour (30 jours)
            if (ke_mois > 0 && ke_jour === 0) {
                ke_jour = ke_mois / 30;
            }

            if (udi <= 0 || delai <= 0 || ke_jour <= 0) {
                alert("Veuillez remplir UDI, Délai et au moins un des deux KE.");
                return;
            }

            // Formules (à adapter selon votre méthode exacte)
            const E = Math.round(Math.sqrt(2 * ke_jour * udi * delai)); // Exemple EOQ simplifié
            const stock_securite = Math.round(udi * delai * 0.3);     // 30% du lead time en exemple
            const e = Math.round(stock_securite);
            const intervalle = (E / udi).toFixed(1);

            document.getElementById('result_E').textContent = E;
            document.getElementById('result_e').textContent = e;
            document.getElementById('result_interval').textContent = intervalle + " jours";

            // Commentaire automatique
            let comm = `✅ Commande économique de ${E} unités tous les ${intervalle} jours.<br>`;
            comm += `📦 Stock minimum recommandé : ${e} unités.`;
            if (intervalle > delai * 2) comm += `<br>⚠️ Intervalle long → risque de rupture possible.`;
            if (intervalle < 2) comm += `<br>🔄 Fréquence très élevée → bonne réactivité.`;
            
            document.getElementById('commentaire').innerHTML = comm;
        }

        function simuler() {
            const udi = parseFloat(document.getElementById('udi').value) || 150;
            const delai = parseFloat(document.getElementById('delai').value) || 5;
            const E = parseFloat(document.getElementById('result_E').textContent) || 800;
            const nbJours = parseInt(document.getElementById('nb_periodes').value) || 30;

            let html = `<strong>Simulation sur ${nbJours} jours (UDI = ${udi})</strong><br><br>`;
            let stock = E;
            let totalCommandes = 0;

            for (let jour = 1; jour <= nbJours; jour++) {
                stock -= udi;
                if (stock <= delai * udi * 1.2) {  // Point de commande
                    stock += E;
                    totalCommandes++;
                    html += `Jour ${jour}: <span class="text-amber-400">Commande lancée</span> → Stock = ${Math.round(stock)}<br>`;
                } else {
                    html += `Jour ${jour}: Stock = ${Math.round(stock)}<br>`;
                }
            }

            html += `<br><strong>Total commandes : ${totalCommandes}</strong>`;
            document.getElementById('simulation_result').innerHTML = html;
        }

        // Permettre le calcul avec Entrée
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') calculer();
        });
    </script>
</body>
</html>
